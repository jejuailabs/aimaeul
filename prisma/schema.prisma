// 마을 공동체 플랫폼 — Prisma schema
// Adapted from upload/01-architecture.md (Firestore) to SQLite.
// SQLite has no arrays/enums — use String (JSON) / String (comma-joined) where needed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// 공동체 (부녀회/청년회/노인회/동호회 등)
model Community {
  id            String   @id @default(cuid())
  communityType String   @default("부녀회") // 부녀회 | 청년회 | 노인회 | 동호회 | ...
  name          String
  regionName    String
  lat           Float
  lng           Float
  inviteCode    String   @unique
  isPublic      Boolean  @default(true)
  coverImageUrl String?
  description   String?
  emojiPackIds  String   @default("[]") // JSON string array
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages      Message[]
  photos        Photo[]
  events        Event[]
  reports       Report[]
  vacantHouses  VacantHouse[]
  dailyDigests  DailyDigest[]
  monthlyDigests MonthlyDigest[]
  histories     History[]
  members       CommunityMember[]

  @@index([isPublic])
  @@index([regionName])
}

/// 커뮤니티-유저 조인 (복수 공동체 소속 지원)
model CommunityMember {
  id          String   @id @default(cuid())
  communityId String
  userId      String
  joinedAt    DateTime @default(now())
  role        String   @default("member") // member | admin

  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String
  photoURL         String?
  themePreference  String   @default("system") // light | dark | system
  bio              String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  communities      CommunityMember[]
  messages         Message[]
  photos           Photo[]
  events           Event[]
  reports          Report[]
  vacantHouses     VacantHouse[]
}

/// 채팅 메시지 (오픈채팅방, 마을 홈페이지 Live Chat과 동일 소스)
model Message {
  id               String   @id @default(cuid())
  communityId      String
  authorId         String
  authorName       String
  authorPhotoURL   String?
  type             String   @default("text") // text | photo | emoji | game_result | system
  text             String?
  photoId          String?
  gameResultPayload String? @default("null") // JSON string
  emojiUrl         String?
  createdAt        DateTime @default(now())

  community        Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author           User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([communityId, createdAt])
  @@index([authorId])
}

model Photo {
  id            String   @id @default(cuid())
  communityId   String
  uploaderId    String
  uploaderName  String
  storageUrl    String
  thumbnailUrl  String
  exifTakenAt   DateTime?
  exifLat       Float?
  exifLng       Float?
  exifDevice    String?
  exifLens      String?
  exifRaw       String   @default("{}") // JSON string
  aiTags        String   @default("[]") // JSON string array
  aiCaption     String?
  aiStory       String?
  createdAt     DateTime @default(now())

  community     Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  uploader      User      @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([communityId, createdAt])
  @@index([uploaderId])
}

model Event {
  id          String   @id @default(cuid())
  communityId String
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  location    String?
  createdById String
  createdAt   DateTime @default(now())

  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([communityId, startAt])
}

model Report {
  id            String   @id @default(cuid())
  communityId   String
  reporterId    String
  photoUrl      String?
  exifRaw       String   @default("{}")
  description   String
  status        String   @default("접수") // 접수 | 안전신문고 전달완료 | 처리중 | 종료
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  community     Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  reporter      User      @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([communityId, createdAt])
  @@index([reporterId])
}

model VacantHouse {
  id          String   @id @default(cuid())
  communityId String
  posterId    String
  photos      String   @default("[]") // JSON string array of URLs
  monthlyRent Int?
  deposit     Int?
  description String?
  lat         Float?
  lng         Float?
  status      String   @default("게시중") // 게시중 | 거래완료 | 게시중지
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  poster      User      @relation(fields: [posterId], references: [id], onDelete: Cascade)

  @@index([communityId, status])
}

model DailyDigest {
  id                       String   @id @default(cuid())
  communityId              String
  date                     String   // "2026-07-20"
  summaryText              String
  topPhotos                String   @default("[]") // JSON array of photoIds
  eventHighlights          String   @default("[]") // JSON string array
  topKeywords              String   @default("[]") // JSON string array
  tomorrowSchedulePreview  String?
  isMemorable              Boolean  @default(false)
  generatedAt              DateTime @default(now())

  community                Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, date])
}

model MonthlyDigest {
  id              String   @id @default(cuid())
  communityId     String
  month           String   // "2026-07"
  photoCount      Int      @default(0)
  eventCount      Int      @default(0)
  messageCount    Int      @default(0)
  newMemberCount  Int      @default(0)
  topPlaces       String   @default("[]") // JSON string array
  topKeywords     String   @default("[]") // JSON string array
  topMembers      String   @default("[]") // JSON string array
  summaryText     String?
  generatedAt     DateTime @default(now())

  community       Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, month])
}

model History {
  id          String   @id @default(cuid())
  communityId String
  title       String
  occurredOn  String   // "2026-07-20"
  keywords    String   @default("[]") // JSON string array
  summary     String
  photoIds    String   @default("[]") // JSON string array
  createdAt   DateTime @default(now())

  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId, occurredOn])
}

model EmojiPack {
  id          String   @id @default(cuid())
  name        String
  images      String   @default("[]") // JSON string array of URLs
  createdBy   String?
  communityId String? // null = 서비스 공통 팩
  createdAt   DateTime @default(now())
}
