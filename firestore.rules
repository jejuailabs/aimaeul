rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 인증된 사용자인지 확인
    function isAuth() {
      return request.auth != null;
    }

    // 본인 문서인지 확인
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // 해당 커뮤니티 멤버인지 확인
    function isMember(communityId) {
      return isAuth() && communityId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.communityIds;
    }

    // users 컬렉션
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);

      // 읽음 위치 서브컬렉션
      match /readPositions/{communityId} {
        allow read, write: if isOwner(uid);
      }
    }

    // communities 컬렉션
    match /communities/{communityId} {
      allow read: if true; // 공개 마을은 비회원도 읽기 가능
      allow write: if isMember(communityId);

      // messages 서브컬렉션
      match /messages/{messageId} {
        allow read: if true; // 비회원 홈페이지 Live Chat 노출용
        allow create: if isMember(communityId);
        allow update, delete: if false;
      }

      // photos 서브컬렉션
      match /photos/{photoId} {
        allow read: if true;
        allow create: if isMember(communityId);
        allow update: if isMember(communityId);
        allow delete: if false;
      }
    }

    // events 컬렉션 (최상위)
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // reports 컬렉션 (최상위)
    match /reports/{reportId} {
      allow read: if isAuth() && (resource.data.reporterId == request.auth.uid);
      allow create: if isAuth();
      allow update: if false; // 관리자 API(admin SDK)로만 변경
      allow delete: if false;
    }

    // vacantHouses 컬렉션 (최상위)
    match /vacantHouses/{listingId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.posterId == request.auth.uid;
      allow delete: if isAuth() && resource.data.posterId == request.auth.uid;
    }

    // dailyDigests 컬렉션 (최상위)
    match /dailyDigests/{digestId} {
      allow read: if true;
      allow write: if false; // 서버(admin SDK)로만 생성
    }

    // monthlyDigests 컬렉션 (최상위)
    match /monthlyDigests/{digestId} {
      allow read: if true;
      allow write: if false;
    }

    // villageHistory 컬렉션 (최상위)
    match /villageHistory/{historyId} {
      allow read: if true;
      allow write: if false; // 서버(admin SDK)로만 생성
    }

    // membershipRequests 컬렉션 (최상위)
    // 생성/승인/거절은 모두 서버(admin SDK)를 통해서만 처리한다.
    // 본인 신청 현황 조회만 클라이언트에 허용.
    match /membershipRequests/{requestId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // emojiPacks 컬렉션 (최상위)
    match /emojiPacks/{packId} {
      allow read: if true;
      allow create: if isAuth();
      allow delete: if isAuth() && resource.data.createdBy == request.auth.uid;
      allow update: if false;
    }
  }
}
